generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity & Access ----------

enum UserRole {
  user
  admin
  moderator
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String?
  displayName     String?
  avatarUrl       String?
  role            UserRole       @default(user)
  emailVerifiedAt DateTime?
  status          String         @default("active")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  oauthAccounts   OAuthAccount[]
  sessions        Session[]
  passwordResets  PasswordReset[]
  emailVerificationTokens EmailVerificationToken[]
  subscriptions   Subscription[]
  favorites       Favorite[]
  notifications   Notification[]
  notificationPrefs NotificationPreference[]
  analyticsEvents AnalyticsEvent[]

  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@map("sessions")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_resets")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("email_verification_tokens")
}

// ---------- Billing ----------

enum SubscriptionPlan {
  free
  premium_monthly
  premium_yearly
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id])
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(active)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  invoices             Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id              String       @id @default(uuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  stripeInvoiceId String
  amount          Int
  currency        String
  status          String
  issuedAt        DateTime

  @@map("invoices")
}

// ---------- Sports Domain ----------

model Sport {
  id       String   @id @default(uuid())
  slug     String   @unique
  name     String
  iconUrl  String?
  isActive Boolean  @default(true)

  competitions Competition[]
  teams        Team[]
  players      Player[]
  matches      Match[]

  @@map("sports")
}

model Competition {
  id         String   @id @default(uuid())
  sportId    String
  sport      Sport    @relation(fields: [sportId], references: [id])
  name       String
  slug       String
  country    String?
  tierWeight Int      @default(10)
  season     String?
  logoUrl    String?

  matches    Match[]
  standings  Standing[]

  @@map("competitions")
}

model Team {
  id          String  @id @default(uuid())
  sportId     String
  sport       Sport   @relation(fields: [sportId], references: [id])
  name        String
  shortName   String?
  country     String?
  logoUrl     String?
  externalRef String?

  players       Player[]
  homeMatches   Match[]  @relation("HomeTeam")
  awayMatches   Match[]  @relation("AwayTeam")

  @@map("teams")
}

model Player {
  id          String  @id @default(uuid())
  sportId     String
  sport       Sport   @relation(fields: [sportId], references: [id])
  teamId      String?
  team        Team?   @relation(fields: [teamId], references: [id])
  name        String
  position    String?
  country     String?
  photoUrl    String?
  externalRef String?

  @@map("players")
}

enum MatchStatus {
  scheduled
  live
  finished
  postponed
}

model Match {
  id             String      @id @default(uuid())
  sportId        String
  sport          Sport       @relation(fields: [sportId], references: [id])
  competitionId  String
  competition    Competition @relation(fields: [competitionId], references: [id])
  homeTeamId     String?
  homeTeam       Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId     String?
  awayTeam       Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  status         MatchStatus @default(scheduled)
  scheduledAt    DateTime
  startedAt      DateTime?
  endedAt        DateTime?
  venue          String?
  homeScore      Int?
  awayScore      Int?
  externalRef    String?
  rawProviderPayload Json?

  events         MatchEvent[]

  @@map("matches")
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  type      String
  minute    Int?
  teamId    String?
  playerId  String?
  payload   Json?
  createdAt DateTime @default(now())

  @@map("match_events")
}

model Standing {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id])
  subjectId     String
  rank          Int
  points        Int         @default(0)
  played        Int         @default(0)
  won           Int         @default(0)
  drawn         Int         @default(0)
  lost          Int         @default(0)
  extra         Json?

  @@map("standings")
}

// ---------- News ----------

model NewsSource {
  id         String   @id @default(uuid())
  name       String
  url        String
  trustScore Int      @default(50)

  articles   NewsArticle[]

  @@map("news_sources")
}

model NewsArticle {
  id          String   @id @default(uuid())
  sourceId    String
  source      NewsSource @relation(fields: [sourceId], references: [id])
  sportId     String?
  title       String
  url         String   @unique
  publishedAt DateTime
  rawContent  String?
  imageUrl    String?

  clusterMemberships ArticleClusterMember[]

  @@map("news_articles")
}

model DedupCluster {
  id                 String   @id @default(uuid())
  canonicalArticleId String
  createdAt          DateTime @default(now())

  members            ArticleClusterMember[]

  @@map("dedup_clusters")
}

model ArticleClusterMember {
  clusterId        String
  cluster          DedupCluster @relation(fields: [clusterId], references: [id])
  articleId        String
  article          NewsArticle  @relation(fields: [articleId], references: [id])
  similarityScore  Float

  @@id([clusterId, articleId])
  @@map("article_cluster_members")
}

// ---------- AI ----------

model AiSummary {
  id                  String   @id @default(uuid())
  subjectType         String
  subjectId           String
  summaryText         String
  modelUsed           String
  generatedAt         DateTime @default(now())
  verifiedAgainstHash String

  @@map("ai_summaries")
}

model TrendingScore {
  id          String   @id @default(uuid())
  subjectType String
  subjectId   String
  score       Float
  components  Json
  computedAt  DateTime @default(now())

  @@map("trending_scores")
}

model MainEvent {
  id        String    @id @default(uuid())
  matchId   String?
  articleId String?
  score     Float
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@map("main_event")
}

// ---------- Engagement ----------

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  subjectType String
  subjectId   String
  createdAt   DateTime @default(now())

  @@unique([userId, subjectType, subjectId])
  @@map("favorites")
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  sportId   String?
  eventType String
  channel   String
  enabled   Boolean @default(true)

  @@map("notification_preferences")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  body        String
  subjectType String?
  subjectId   String?
  sentAt      DateTime  @default(now())
  readAt      DateTime?

  @@map("notifications")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  eventName  String
  properties Json?
  occurredAt DateTime @default(now())

  @@map("analytics_events")
}
