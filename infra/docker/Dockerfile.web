# Generic Dockerfile for a Next.js app in apps/* (web or admin).
# Build: docker build -f infra/docker/Dockerfile.web --build-arg PACKAGE_NAME=@vyntro/web --build-arg APP_DIR=apps/web --build-arg PORT=3000 -t vyntro-web .
FROM node:20-alpine AS base
WORKDIR /repo
RUN apk add --no-cache openssl

FROM base AS deps
COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY apps ./apps
COPY services ./services
COPY workers ./workers
COPY packages ./packages
RUN npm ci

FROM deps AS build
ARG PACKAGE_NAME
RUN npx prisma generate --schema packages/db/prisma/schema.prisma
RUN npx turbo run build --filter=${PACKAGE_NAME}

FROM node:20-alpine AS runner
WORKDIR /repo
ENV NODE_ENV=production
COPY --from=build /repo /repo
ARG APP_DIR
ARG PORT=3000
ENV APP_DIR=${APP_DIR}
ENV PORT=${PORT}
EXPOSE ${PORT}
CMD ["sh", "-c", "cd ${APP_DIR} && npx next start -p ${PORT}"]
